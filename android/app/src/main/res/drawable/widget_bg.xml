<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 外阴影层（底部偏深） -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#22000000" />
            <corners android:radius="18dp" />
        </shape>
    </item>
    <!-- 主背景（浅灰拟态底色） -->
    <item android:bottom="0dp" android:left="1dp" android:right="1dp" android:top="1dp">
        <shape android:shape="rectangle">
            <solid android:color="#E8EDF2" />
            <corners android:radius="18dp" />
        </shape>
    </item>
    <!-- 内层高光（顶部偏亮模拟光源） -->
    <item android:bottom="2dp" android:left="2dp" android:right="2dp" android:top="0dp">
        <shape android:shape="rectangle">
            <solid android:color="#F5F8FB" />
            <corners android:radius="16dp" />
        </shape>
    </item>
</layer-list>
