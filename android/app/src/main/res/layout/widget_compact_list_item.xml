<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/widget_compact_card_bg"
    android:padding="8dp"
    android:layout_marginStart="2dp"
    android:layout_marginEnd="2dp">

    <TextView
        android:id="@+id/compact_item_time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="08:30"
        android:textSize="12sp"
        android:textColor="@color/widget_courses_color" />

    <TextView
        android:id="@+id/compact_item_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="高等数学"
        android:textSize="14sp"
        android:textColor="@color/widget_title_color"
        android:textStyle="bold"
        android:maxLines="1"
        android:ellipsize="end"
        android:layout_marginTop="2dp" />

    <TextView
        android:id="@+id/compact_item_room"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="📍 A301"
        android:textSize="12sp"
        android:textColor="@color/widget_courses_color"
        android:maxLines="1"
        android:ellipsize="end"
        android:layout_marginTop="2dp" />

</LinearLayout>
